# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{toml,yaml,yml,json,md,qmd}]
indent_style = space
indent_size = 2

[justfile]
indent_style = space
indent_size = 4
