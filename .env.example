# Copy to .env (gitignored) and fill in. `just` auto-loads .env (set dotenv-load), and
# src/transfer_risk/settings.py also loads it so direct `uv run kedro run` picks it up.
# Existing shell variables win, so anything already exported is not overridden.

# HuggingFace access token (read scope) for gated models (Llama Prompt Guard 2,
# protectai/deberta-v3-small-prompt-injection-v2). Optional if you authenticated with
# `huggingface-cli login` (the token cache is used instead). Create one at
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Opt out of kedro-telemetry.
DO_NOT_TRACK=1

# Apple-Silicon / PyTorch runtime flags: let unsupported MPS ops fall back to CPU, lift
# the MPS memory-watermark cap, and quiet the tokenizers + HF download chatter.
PYTORCH_ENABLE_MPS_FALLBACK=1
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0
TOKENIZERS_PARALLELISM=false
HF_HUB_DISABLE_PROGRESS_BARS=1
# Cap each HF download request so a stalled CDN stream errors+retries instead of hanging.
HF_HUB_DOWNLOAD_TIMEOUT=20
